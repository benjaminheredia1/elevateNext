// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum EstadoTransaccion {
  PENDIENTE
  EN_PREPARACION
  LISTO
  EN_LOCAL
  EN_CAMINO
  LLEGO
  ENTREGADO
  CANCELADO
  PAGADO
}

// Estado de pago, independiente del estado de cumplimiento (estado)
enum EstadoPago {
  PENDIENTE
  PAGADO
  REEMBOLSADO
  COD_PENDIENTE
}

enum Rol {
  DUENO
  ADMIN
  CAJERO
  CLIENTE
}

enum AccionAuditoria {
  CREO
  MODIFICO
  ELIMINO
  LOGIN
  LOGOUT
  APERTURA_CAJA
  CIERRE_CAJA
}

enum TipoCuenta {
  EFECTIVO
  QR
  TARJETA
  BANCO
  // Pago dividido QR + efectivo (solo Transaccion.metodo_pago; el desglose
  // real vive en los MovimientoCaja hijos, que siempre son EFECTIVO o QR)
  MIXTO
}

enum EstadoTurno {
  ABIERTO
  CERRADO
}

enum TipoMovimientoCaja {
  VENTA
  INGRESO_EXTRA
  GASTO_OPERATIVO
  COMPRA_INSUMO
  AJUSTE
  RETIRO
}

enum CanalVenta {
  WEB
  PICKUP
  SALON
}

enum TipoEntrega {
  RECOJO
  DELIVERY
}

enum Frecuencia {
  MENSUAL
  QUINCENAL
  SEMANAL
  ANUAL
}

enum EstadoCuenta {
  PENDIENTE
  PARCIAL
  PAGADA
}

enum TipoCuentaCxCxP {
  POR_COBRAR
  POR_PAGAR
}

model Usuario {
  id                   Int                 @id @default(autoincrement())
  nombre               String
  apellido_paterno     String
  apellido_materno     String
  email                String              @unique
  username             String?             @unique
  password             String
  token                String
  rol                  Rol                 @default(CLIENTE)
  activo               Boolean             @default(true)
  ultimo_acceso        DateTime?
  sucursal_id          Int?
  sucursal             Sucursal?           @relation(fields: [sucursal_id], references: [id])
  transaccion_id       Transaccion[]       @relation("UsuarioTransacciones")
  transacciones_cajero Transaccion[]       @relation("CajeroTransacciones")
  turnos_caja          CajaTurno[]
  movimientos_caja     MovimientoCaja[]
  cajas                Caja[]
  auditorias           RegistroAuditoria[]
  horarios             HorarioTrabajador[]
  password_reset_tokens PasswordResetToken[]
  created_at           DateTime            @default(now())
  update_at            DateTime            @updatedAt
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  usuario_id Int
  usuario    Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([usuario_id])
}

model Cliente {
  id                 Int                 @id @default(autoincrement())
  nombre             String
  telefono           String?             @unique
  email              String?
  nit                String?
  direccion          String?
  es_anonimo         Boolean             @default(false)
  transacciones      Transaccion[]
  cuentas_corrientes CuentaCorriente[]
  privilegios        ClientePrivilegio[]
  created_at         DateTime            @default(now())
  update_at          DateTime            @updatedAt
}

model Privilegio {
  id            Int                 @id @default(autoincrement())
  nombre        String
  descripcion   String?
  porcentaje    Decimal             @db.Decimal(5, 2)
  activo        Boolean             @default(true)
  creado_por_id Int
  clientes      ClientePrivilegio[]
  created_at    DateTime            @default(now())
  update_at     DateTime            @updatedAt

  @@index([activo])
}

model ClientePrivilegio {
  cliente_id    Int
  privilegio_id Int
  created_at    DateTime   @default(now())
  cliente       Cliente    @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  privilegio    Privilegio @relation(fields: [privilegio_id], references: [id], onDelete: Cascade)

  @@id([cliente_id, privilegio_id])
  @@index([privilegio_id])
}

model Transaccion {
  id         Int      @id @default(autoincrement())
  usuario_id Int?
  usuario    Usuario? @relation("UsuarioTransacciones", fields: [usuario_id], references: [id])

  cliente_id Int?
  cliente    Cliente? @relation(fields: [cliente_id], references: [id])

  cliente_nombre    String?
  cliente_telefono  String?
  cliente_direccion String?
  cliente_lat       Float?
  cliente_lng       Float?
  cliente_nit       String?
  cliente_email     String?
  tipo_entrega      TipoEntrega?
  codigo_descuento  String?
  metodo_pago       TipoCuenta?
  total             Decimal           @db.Decimal(12, 2)
  estado            EstadoTransaccion @default(PENDIENTE)
  payment_status    EstadoPago        @default(PENDIENTE)
  codigo            String?           @unique

  // Operación presencial / canal
  canal       CanalVenta?
  es_cortesia Boolean     @default(false)
  turno_id    Int?
  turno       CajaTurno?  @relation(fields: [turno_id], references: [id])
  cajero_id   Int?
  cajero      Usuario?    @relation("CajeroTransacciones", fields: [cajero_id], references: [id])

  // Driver tracking fields
  driver_nombre  String?
  driver_lat     Float?
  driver_lng     Float?
  driver_link_id String? @unique

  transaccionesDetalles_id TransaccionesDetalles[]
  movimientos              MovimientoCaja[]
  movimientos_internos     MovimientoInterno[]
  cuenta_corriente         CuentaCorriente?
  created_at               DateTime                @default(now())
  update_at                DateTime                @updatedAt
}

model Categoria {
  id           Int                  @id @default(autoincrement())
  nombre       String
  detalles     String
  categoria_id CategoriasProducto[]
  created_at   DateTime             @default(now())
  update_at    DateTime             @updatedAt
}

model Producto {
  id                       Int                     @id @default(autoincrement())
  nombre                   String
  descripcion              String
  precio                   Decimal                 @db.Decimal(12, 2)
  imagen_url               String?
  disponible               Boolean                 @default(true)
  // FASE 5A — tipo, publicación, nutrición y marcas
  tipo                     ProductoTipo            @default(ELABORADO)
  estado_publicacion       EstadoPublicacion       @default(BORRADOR)
  insumo_reventa_id        Int?
  insumo_reventa           Insumo?                 @relation("InsumoReventa", fields: [insumo_reventa_id], references: [id])
  ventas_acumuladas        Int                     @default(0)
  calorias                 Int?
  proteina                 String?
  // Baja definitiva del producto (retiro del catálogo)
  motivo_baja              String?
  fecha_baja               DateTime?
  // En revisión: cuando un insumo en su receta fue dado de baja
  en_revision              Boolean                 @default(false)
  revision_desde           DateTime?
  motivo_revision          String?
  insumo_causa_revision_id Int?
  categoria_id             CategoriasProducto[]
  created_at               DateTime                @default(now())
  update_at                DateTime                @updatedAt
  recetaProducto_id        RecetasProducto[]
  promocionProducto_id     PromocionProducto[]
  transaccionesDetalles_id TransaccionesDetalles[]
  marcas                   ProductoMarca[]
}

model TransaccionesDetalles {
  id                Int         @id @default(autoincrement())
  transaccion_id    Int
  precio_unitario   Decimal     @db.Decimal(12, 2)
  descuentoAplicado Decimal     @default(0) @db.Decimal(12, 2)
  producto_id       Int
  cantidad          Float
  transaccion       Transaccion @relation(fields: [transaccion_id], references: [id], onDelete: Cascade)
  producto          Producto    @relation(fields: [producto_id], references: [id])
}

model CategoriasProducto {
  id           Int       @id @default(autoincrement())
  categoria_id Int
  producto_id  Int
  categoria    Categoria @relation(fields: [categoria_id], references: [id])
  producto     Producto  @relation(fields: [producto_id], references: [id])
  created_at   DateTime  @default(now())
  update_at    DateTime  @updatedAt
}

model UnidadMedida {
  id         Int      @id @default(autoincrement())
  nombre     String   @unique
  activo     Boolean  @default(true)
  created_at DateTime @default(now())
  update_at  DateTime @updatedAt
}

model Insumo {
  id                   Int                  @id @default(autoincrement())
  nombre               String
  stock_actual         Float
  stock_minimo         Float
  unidad_medida        String
  costo_promedio       Float                @default(0)
  es_mixto             Boolean              @default(false)
  // FASE 5A — campos de inventario avanzado
  punto_critico        Float                @default(0)
  categoria_insumo     String?
  rendimiento          Float?
  proveedor            String?
  proveedor_telefono   String?
  uso_diario_promedio  Float?
  // Baja definitiva del insumo (retiro del inventario)
  activo               Boolean              @default(true)
  fecha_baja           DateTime?
  motivo_baja          String?
  // Equivalencia informativa (ej. 1 UNIDAD = 300 GR) — no afecta stock/recetas
  equivalencia_unidad   String?
  equivalencia_cantidad Float?
  movimientoInterno_id MovimientoInterno[]
  recetaProducto_id    RecetasProducto[]
  insumos_mixtos_padre InsumoMixtoDetalle[] @relation("InsumoPadre")
  insumos_mixtos_hijo  InsumoMixtoDetalle[] @relation("InsumoHijo")
  productos_reventa    Producto[]           @relation("InsumoReventa")
  created_at           DateTime             @default(now())
  update_at            DateTime             @updatedAt
}

model InsumoMixtoDetalle {
  id              Int    @id @default(autoincrement())
  insumo_padre_id Int
  insumo_hijo_id  Int
  cantidad        Float
  insumo_padre    Insumo @relation("InsumoPadre", fields: [insumo_padre_id], references: [id])
  insumo_hijo     Insumo @relation("InsumoHijo", fields: [insumo_hijo_id], references: [id])
}

model RecetasProducto {
  id                 Int      @id @default(autoincrement())
  producto_id        Int
  insumo_id          Int
  cantidad_utilizada Float
  producto           Producto @relation(fields: [producto_id], references: [id])
  insumo             Insumo   @relation(fields: [insumo_id], references: [id])
  created_at         DateTime @default(now())
  update_at          DateTime @updatedAt
}

enum Tipo_movimiento {
  INGRESO
  EGRESO
  PRODUCCION
  VENTA
  MERMA
  AJUSTE
  BAJA
}

enum ProductoTipo {
  ELABORADO
  REVENTA
}

enum EstadoPublicacion {
  BORRADOR
  PUBLICADO
  ARCHIVADO
  BAJA
}

model MovimientoInterno {
  id              Int             @id @default(autoincrement())
  insumo_id       Int
  tipo_movimiento Tipo_movimiento
  cantidad        Float
  descripcion     String
  // FASE 5A — trazabilidad extendida
  costo_unitario  Float?
  responsable     String?
  transaccion_id  Int?
  insumo          Insumo          @relation(fields: [insumo_id], references: [id])
  transaccion     Transaccion?    @relation(fields: [transaccion_id], references: [id])
  created_at      DateTime        @default(now())
  update_at       DateTime        @updatedAt
}

model PromocionProducto {
  id                      Int                   @id @default(autoincrement())
  producto_id             Int
  key                     String
  promocion_descuentos_id Int
  promocionDescuentos     PromocionesDescuentos @relation(fields: [promocion_descuentos_id], references: [id])
  producto                Producto              @relation(fields: [producto_id], references: [id])
}

model PromocionesDescuentos {
  id                   Int                 @id @default(autoincrement())
  nombre               String
  valor                String
  promocionProducto_id PromocionProducto[]
  reglasHorarias_id    ReglasHorarias[]
}

model ReglasHorarias {
  id                       Int                   @id @default(autoincrement())
  promocionesDescuentos_id Int
  fecha_inicio             DateTime
  fecha_fin                DateTime
  promocionesDescuentos    PromocionesDescuentos @relation(fields: [promocionesDescuentos_id], references: [id])
}

model Configuracion {
  id              Int      @id @default(1)
  sucursal_lat    Float
  sucursal_lng    Float
  sucursal_nombre String
  created_at      DateTime @default(now())
  update_at       DateTime @updatedAt
}

enum EstadoCaja {
  ABIERTA
  CERRADA
}

model Caja {
  id             Int        @id @default(autoincrement())
  monto_inicial  Decimal    @default(0) @db.Decimal(12, 2)
  monto_final    Decimal?   @db.Decimal(12, 2)
  ingresos       Decimal    @default(0) @db.Decimal(12, 2)
  egresos        Decimal    @default(0) @db.Decimal(12, 2)
  estado         EstadoCaja @default(ABIERTA)
  fecha_apertura DateTime   @default(now())
  fecha_cierre   DateTime?
  usuario_id     Int
  usuario        Usuario    @relation(fields: [usuario_id], references: [id])
  gastos         Gasto[]
}

model Gasto {
  id          Int      @id @default(autoincrement())
  caja_id     Int
  monto       Decimal  @db.Decimal(12, 2)
  descripcion String
  caja        Caja     @relation(fields: [caja_id], references: [id])
  created_at  DateTime @default(now())
}

/**
 * ===== Multi-sucursal (generaliza Configuracion) =====
 */
model Sucursal {
  id         Int                @id @default(autoincrement())
  nombre     String
  direccion  String?
  lat        Float?
  lng        Float?
  activa     Boolean            @default(true)
  usuarios     Usuario[]
  cuentas      CuentaFinanciera[]
  turnos       CajaTurno[]
  diasFeriados DiaFeriado[]
  created_at   DateTime           @default(now())
  update_at    DateTime           @updatedAt
}

/**
 * ===== Auditoria (trazabilidad, append-only) =====
 */
model RegistroAuditoria {
  id         Int             @id @default(autoincrement())
  usuario_id Int
  rol        Rol
  accion     AccionAuditoria
  entidad    String
  entidad_id String?
  detalle    String
  monto      Decimal?        @db.Decimal(12, 2)
  ip         String?
  user_agent String?
  created_at DateTime        @default(now())

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@index([usuario_id])
  @@index([created_at])
  @@index([entidad])
}

model GastoFijo {
  id            Int        @id @default(autoincrement())
  concepto      String
  categoria     String
  monto         Decimal    @db.Decimal(12, 2)
  frecuencia    Frecuencia @default(MENSUAL)
  activo        Boolean    @default(true)
  creado_por_id Int
  created_at    DateTime   @default(now())
  update_at     DateTime   @updatedAt

  @@index([activo])
  @@index([categoria])
}

model GastoOperativo {
  id            Int        @id @default(autoincrement())
  concepto      String
  categoria     String
  monto         Decimal    @db.Decimal(12, 2)
  metodo_pago   TipoCuenta
  fecha         DateTime
  notas         String?
  creado_por_id Int
  created_at    DateTime   @default(now())
  update_at     DateTime   @updatedAt

  @@index([fecha])
  @@index([categoria])
  @@index([metodo_pago])
}

/**
 * ===== CUENTAS FINANCIERAS (Caja Efectivo / QR / Banco) =====
 */
model CuentaFinanciera {
  id          Int              @id @default(autoincrement())
  sucursal_id Int
  tipo        TipoCuenta
  nombre      String
  saldo       Decimal          @default(0) @db.Decimal(12, 2)
  sucursal    Sucursal         @relation(fields: [sucursal_id], references: [id])
  movimientos MovimientoCaja[]
  created_at  DateTime         @default(now())
  update_at   DateTime         @updatedAt

  @@unique([sucursal_id, tipo])
}

/**
 * ===== TURNO DE CAJA (apertura / cierre) =====
 */
model CajaTurno {
  id                  Int              @id @default(autoincrement())
  sucursal_id         Int
  cajero_id           Int
  estado              EstadoTurno      @default(ABIERTO)
  apertura_efectivo   Decimal          @default(0) @db.Decimal(12, 2)
  apertura_qr         Decimal          @default(0) @db.Decimal(12, 2)
  fecha_apertura      DateTime         @default(now())
  ventas_efectivo     Decimal          @default(0) @db.Decimal(12, 2)
  ventas_qr           Decimal          @default(0) @db.Decimal(12, 2)
  esperado_efectivo   Decimal?         @db.Decimal(12, 2)
  esperado_qr         Decimal?         @db.Decimal(12, 2)
  real_efectivo       Decimal?         @db.Decimal(12, 2)
  real_qr             Decimal?         @db.Decimal(12, 2)
  diferencia_efectivo Decimal?         @db.Decimal(12, 2)
  diferencia_qr       Decimal?         @db.Decimal(12, 2)
  observaciones       String?
  fecha_cierre        DateTime?
  sucursal            Sucursal         @relation(fields: [sucursal_id], references: [id])
  cajero              Usuario          @relation(fields: [cajero_id], references: [id])
  movimientos         MovimientoCaja[]
  ventas              Transaccion[]
  created_at          DateTime         @default(now())
  update_at           DateTime         @updatedAt

  @@index([sucursal_id, estado])
  @@index([fecha_apertura])
}

/**
 * ===== MOVIMIENTO DE CAJA (libro del turno) =====
 */
model CuentaCorriente {
  id             Int             @id @default(autoincrement())
  tipo           TipoCuentaCxCxP
  contraparte    String
  concepto       String
  monto          Decimal         @db.Decimal(12, 2)
  monto_pagado   Decimal         @default(0) @db.Decimal(12, 2)
  vencimiento    DateTime?
  estado         EstadoCuenta    @default(PENDIENTE)
  creado_por_id  Int
  // Relaciones opcionales para "fiado"
  cliente_id     Int?
  transaccion_id Int?            @unique
  cliente        Cliente?        @relation(fields: [cliente_id], references: [id])
  transaccion    Transaccion?    @relation(fields: [transaccion_id], references: [id])
  created_at     DateTime        @default(now())
  update_at      DateTime        @updatedAt

  @@index([tipo, estado])
  @@index([cliente_id])
  @@index([vencimiento])
}

model ActivoFijo {
  id               Int      @id @default(autoincrement())
  nombre           String
  categoria        String
  fecha_compra     DateTime
  valor_original   Decimal  @db.Decimal(12, 2)
  valor_actual     Decimal  @db.Decimal(12, 2)
  depreciacion_pct Decimal? @db.Decimal(5, 2)
  notas            String?
  activo           Boolean  @default(true)
  creado_por_id    Int
  created_at       DateTime @default(now())
  update_at        DateTime @updatedAt

  @@index([activo])
  @@index([categoria])
}

model MovimientoCaja {
  id             Int                @id @default(autoincrement())
  turno_id       Int?
  cuenta_id      Int
  tipo           TipoMovimientoCaja
  metodo_pago    TipoCuenta
  monto          Decimal            @db.Decimal(12, 2)
  concepto       String
  categoria      String?
  transaccion_id Int?
  es_cortesia    Boolean            @default(false)
  creado_por_id  Int
  created_at     DateTime           @default(now())

  turno       CajaTurno?       @relation(fields: [turno_id], references: [id])
  cuenta      CuentaFinanciera @relation(fields: [cuenta_id], references: [id])
  transaccion Transaccion?     @relation(fields: [transaccion_id], references: [id])
  creado_por  Usuario          @relation(fields: [creado_por_id], references: [id])

  @@index([turno_id])
  @@index([created_at])
  @@index([tipo, metodo_pago])
}

// ===== FASE 5A — Inventario avanzado =====

model Marca {
  id         Int             @id @default(autoincrement())
  key        String          @unique // "elevate" | "fitbull"
  nombre     String
  color      String?
  productos  ProductoMarca[]
  created_at DateTime        @default(now())
  update_at  DateTime        @updatedAt
}

model ProductoMarca {
  id          Int      @id @default(autoincrement())
  producto_id Int
  marca_id    Int
  producto    Producto @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  marca       Marca    @relation(fields: [marca_id], references: [id], onDelete: Cascade)

  @@unique([producto_id, marca_id])
}

model ConfiguracionAlertas {
  id                   Int      @id @default(1)
  whatsapp_habilitado  Boolean  @default(false)
  destinatarios        String[] @default([])
  hora_silencio_desde  String   @default("22:00")
  hora_silencio_hasta  String   @default("07:00")
  intervalo_minimo_min Int      @default(60)
  plantilla_mensaje    String   @default("Elevate - Alerta de inventario: {count} insumos bajo umbral.\n{list}")
  created_at           DateTime @default(now())
  update_at            DateTime @updatedAt
}

model RegistroAlerta {
  id         Int      @id @default(autoincrement())
  enviado_at DateTime @default(now())
  canal      String   @default("whatsapp")
  insumo_ids Int[]    @default([])
  estado     String // sent | failed | simulated
  preview    String
}

model HorarioTrabajador {
  id           Int      @id @default(autoincrement())
  usuario_id   Int
  dia_semana   Int      // 1=lunes ... 7=domingo (ISO 8601)
  es_libre     Boolean  @default(false)
  hora_entrada String?  // "HH:MM", null cuando es_libre = true
  hora_salida  String?  // "HH:MM", null cuando es_libre = true
  usuario      Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  created_at   DateTime @default(now())
  update_at    DateTime @updatedAt

  @@unique([usuario_id, dia_semana])
}

model DiaFeriado {
  id          Int       @id @default(autoincrement())
  fecha       DateTime  @db.Date
  nombre      String
  sucursal_id Int?
  sucursal    Sucursal? @relation(fields: [sucursal_id], references: [id])
  created_at  DateTime  @default(now())

  @@unique([fecha, sucursal_id])
}
