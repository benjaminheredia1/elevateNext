# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
# e2e temporales con credenciales reales y que mutan la BD compartida — no versionar
*.e2e.test.ts

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-server*.log

# uploaded product images (user content, not source)
/public/uploads/

# local archives and screenshots
*.zip
*.7z
*.rar
*.tar
*.tar.gz
/imagesExtra/

# env files (can opt-in for committing if needed)
.env*
!.env.test.example
!.env.dev.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Backups de base de datos (datos sensibles, no versionar)
/backups/
