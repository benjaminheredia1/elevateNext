{
  "name": "elevatenextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "dotenv -e .env.dev -- next dev",
    "db:local": "dotenv -e .env.dev -- prisma db push && dotenv -e .env.dev -- prisma db seed",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "electron .",
    "electron:build": "electron-builder build --win",
    "pretest": "dotenv -e .env.test -- prisma db push && dotenv -e .env.test -- prisma db seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@types/leaflet": "^1.9.21",
    "@vercel/blob": "^2.5.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "nanoid": "^5.1.16",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "main": "main.js",
  "build": {
    "appId": "com.elevatenextjs.app",
    "productName": "Elevate",
    "directories": {
      "output": "dist_electron"
    }
  }
}
